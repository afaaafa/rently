<% content_for :title, "Criar conta — Rently" %>

<div class="rently-auth-split">
  <div class="rently-contract-panel">
    <span class="rently-eyebrow">Cadastro de cliente</span>
    <h1 class="rently-display mt-5 text-6xl font-black leading-none">Entre na fila certa.</h1>
    <p class="rently-copy mt-5">
      A conta de cliente libera o envio de pedidos de aluguel e o acompanhamento de status até a análise da locadora.
    </p>
    <ul class="rently-mini-list mt-8">
      <li>Dados pessoais para identificação</li>
      <li>Profissão e endereço para o pedido</li>
      <li>Acesso imediato após criar a conta</li>
    </ul>
  </div>

  <div class="rently-panel rently-panel-pad">
    <span class="rently-eyebrow">Nova conta</span>
    <h2 class="rently-section-title mt-3">Criar conta</h2>

    <%= form_with model: @cliente, url: registration_path, class: "block mt-6 space-y-5" do |form| %>
      <% if @cliente.errors.any? %>
        <div class="bg-red-50 border-2 border-red-200 rounded-lg p-4">
          <p class="text-sm font-black text-red-700 mb-1">
            <%= pluralize(@cliente.errors.count, "erro") %> impediram o cadastro:
          </p>
          <ul class="list-disc list-inside text-sm font-bold text-red-600 space-y-0.5">
            <% @cliente.errors.each do |error| %>
              <li><%= error.full_message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div class="sm:col-span-2">
          <%= form.label :name, "Nome completo", class: "rently-label" %>
          <%= form.text_field :name, required: true, autocomplete: "name", placeholder: "Seu nome completo", class: "rently-input" %>
        </div>

        <div>
          <%= form.label :rg, "RG", class: "rently-label" %>
          <%= form.text_field :rg, required: true, placeholder: "00.000.000-0", class: "rently-input" %>
        </div>

        <div>
          <%= form.label :cpf, "CPF", class: "rently-label" %>
          <%= form.text_field :cpf, required: true, placeholder: "000.000.000-00", class: "rently-input" %>
        </div>

        <div class="sm:col-span-2">
          <%= form.label :address_text, "Endereço", class: "rently-label" %>
          <%= form.text_field :address_text, required: true, value: @address_text || @cliente.address&.dig("line"), autocomplete: "street-address", placeholder: "Rua, número, bairro, cidade", class: "rently-input" %>
        </div>

        <div class="sm:col-span-2">
          <%= form.label :profession, "Profissão", class: "rently-label" %>
          <%= form.text_field :profession, required: true, placeholder: "Sua profissão", class: "rently-input" %>
        </div>

        <div class="sm:col-span-2">
          <%= form.label :email_address, "E-mail", class: "rently-label" %>
          <%= form.email_field :email_address, required: true, autocomplete: "email", placeholder: "voce@exemplo.com", class: "rently-input" %>
        </div>

        <div>
          <%= form.label :password, "Senha", class: "rently-label" %>
          <%= form.password_field :password, required: true, autocomplete: "new-password", maxlength: 72, placeholder: "Crie uma senha", class: "rently-input" %>
        </div>

        <div>
          <%= form.label :password_confirmation, "Confirmar senha", class: "rently-label" %>
          <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", maxlength: 72, placeholder: "Repita a senha", class: "rently-input" %>
        </div>
      </div>

      <div class="flex flex-wrap items-center gap-4">
        <%= form.submit "Criar conta", class: "rently-button cursor-pointer" %>
        <%= link_to "Já tenho conta", new_session_path, class: "rently-button-ghost" %>
      </div>
    <% end %>
  </div>
</div>
