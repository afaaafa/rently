<% content_for :title, "Pedido de #{@pedido.client.name} — Rently" %>

<div class="max-w-6xl mx-auto">
  <%= link_to "Voltar para pedidos", pedidos_path, class: "rently-button-ghost" %>

  <div class="mt-6 grid grid-cols-1 lg:grid-cols-5 gap-6 items-start">
    <div class="lg:col-span-2 rently-panel rently-panel-pad">
      <div class="flex items-start justify-between gap-4">
        <div>
          <span class="rently-eyebrow">Pedido de aluguel</span>
          <h1 class="rently-section-title mt-3"><%= @pedido.client.name %></h1>
          <p class="text-sm font-bold text-gray-600 mt-2">Solicitado em <%= @pedido.request_date.strftime("%d/%m/%Y") %></p>
        </div>
        <%= render "dashboard/status_badge", status: @pedido.status %>
      </div>

      <dl class="mt-6 space-y-3">
        <div class="rently-spec p-4">
          <dt class="text-xs font-black text-gray-500 uppercase">CPF</dt>
          <dd class="text-sm font-black text-gray-900 mt-1"><%= @pedido.client.cpf %></dd>
        </div>
        <div class="rently-spec p-4">
          <dt class="text-xs font-black text-gray-500 uppercase">Profissão</dt>
          <dd class="text-sm font-black text-gray-900 mt-1"><%= @pedido.client.profession %></dd>
        </div>
        <div class="rently-spec p-4">
          <dt class="text-xs font-black text-gray-500 uppercase">Agente</dt>
          <dd class="text-sm font-black text-gray-900 mt-1"><%= @pedido.agent&.name || "Ainda não selecionado" %></dd>
        </div>
        <div class="rently-spec p-4">
          <dt class="text-xs font-black text-gray-500 uppercase">Automóvel solicitado</dt>
          <dd class="text-sm font-black text-gray-900 mt-1"><%= @pedido.automovel.brand %> <%= @pedido.automovel.model %> · <%= @pedido.automovel.plate %></dd>
        </div>
        <div class="rently-spec p-4">
          <dt class="text-xs font-black text-gray-500 uppercase">Diária</dt>
          <dd class="rently-display text-3xl font-black mt-1"><%= number_to_currency(@pedido.automovel.daily_rate, unit: "R$ ", separator: ",", delimiter: ".") %></dd>
        </div>
      </dl>

      <% if @pedido.pending? %>
        <div class="mt-6">
          <%= button_to "Selecionar para análise",
                start_review_pedido_path(@pedido),
                method: :patch,
                class: "rently-button w-full cursor-pointer" %>
        </div>
      <% end %>

      <% if @pedido.pending? || @pedido.under_review? %>
        <div class="mt-3">
          <%= button_to "Recusar pedido",
                reject_pedido_path(@pedido),
                method: :patch,
                form: { data: { turbo_confirm: "Recusar este pedido?" } },
                class: "rently-button-danger w-full cursor-pointer" %>
        </div>
      <% end %>
    </div>

    <div class="lg:col-span-3 rently-panel rently-panel-pad">
      <% if @pedido.approved? && @pedido.contrato_aluguel&.persisted? %>
        <span class="rently-eyebrow">Contrato executado</span>
        <h2 class="rently-display text-4xl font-black mt-3"><%= @pedido.automovel.brand %> <%= @pedido.automovel.model %></h2>
        <dl class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div class="rently-spec p-4">
            <dt class="text-xs font-black text-gray-500 uppercase">Tipo</dt>
            <dd class="text-sm font-black text-gray-900 mt-1"><%= @pedido.contrato_aluguel.contract_type %></dd>
          </div>
          <div class="rently-spec p-4">
            <dt class="text-xs font-black text-gray-500 uppercase">Valor</dt>
            <dd class="rently-display text-3xl font-black mt-1"><%= number_to_currency(@pedido.contrato_aluguel.total_value, unit: "R$ ", separator: ",", delimiter: ".") %></dd>
          </div>
          <div class="rently-spec p-4">
            <dt class="text-xs font-black text-gray-500 uppercase">Início</dt>
            <dd class="text-sm font-black text-gray-900 mt-1"><%= @pedido.contrato_aluguel.start_date.strftime("%d/%m/%Y") %></dd>
          </div>
          <div class="rently-spec p-4">
            <dt class="text-xs font-black text-gray-500 uppercase">Fim</dt>
            <dd class="text-sm font-black text-gray-900 mt-1"><%= @pedido.contrato_aluguel.end_date.strftime("%d/%m/%Y") %></dd>
          </div>
        </dl>
      <% elsif @pedido.rejected? %>
        <div class="py-16 text-center">
          <p class="rently-display text-3xl font-black">Pedido recusado.</p>
          <p class="text-sm font-bold text-gray-500 mt-2">O parecer negativo foi registrado.</p>
        </div>
      <% else %>
        <span class="rently-eyebrow">Parecer positivo</span>
        <h2 class="rently-display text-4xl font-black mt-3">Executar contrato</h2>
        <p class="text-sm font-bold text-gray-600 mt-2">
          O contrato será emitido para <%= @pedido.automovel.brand %> <%= @pedido.automovel.model %>, escolhido pelo cliente.
        </p>

        <%= form_with model: @contrato_aluguel, url: approve_pedido_path(@pedido), method: :patch, class: "space-y-6 mt-6" do |f| %>
          <% if @contrato_aluguel.errors.any? %>
            <div class="bg-red-50 border-2 border-red-200 rounded-lg p-4">
              <p class="text-sm font-black text-red-700 mb-1">
                <%= pluralize(@contrato_aluguel.errors.count, "erro") %> impediram a aprovação:
              </p>
              <ul class="list-disc list-inside text-sm font-bold text-red-600 space-y-0.5">
                <% @contrato_aluguel.errors.each do |error| %>
                  <li><%= error.full_message %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <%= f.label :contract_type, "Propriedade do contrato", class: "rently-label" %>
              <%= f.select :contract_type,
                    [["Cliente", "client"], ["Empresa", "company"], ["Banco", "bank"]],
                    {},
                    class: "rently-input" %>
            </div>

            <div>
              <%= f.label :start_date, "Data de início", class: "rently-label" %>
              <%= f.date_field :start_date, class: "rently-input" %>
            </div>

            <div>
              <%= f.label :end_date, "Data de fim", class: "rently-label" %>
              <%= f.date_field :end_date, class: "rently-input" %>
            </div>

            <div class="rently-spec p-4">
              <dt class="text-xs font-black text-gray-500 uppercase">Valor calculado</dt>
              <dd class="text-sm font-bold text-gray-700 mt-1">Diária multiplicada pela duração do contrato.</dd>
            </div>
          </div>

          <div class="flex flex-wrap items-center gap-4 pt-2">
            <%= f.submit "Aprovar e executar contrato", class: "rently-button cursor-pointer" %>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
