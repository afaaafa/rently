<% content_for :title, "Pedidos — Rently" %>

<div class="space-y-8">
  <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <span class="rently-eyebrow">Fila da locadora</span>
      <h1 class="rently-section-title mt-3">Pedidos dos clientes</h1>
      <p class="text-sm font-bold text-gray-600 mt-2">
        <%= pluralize(@pending_pedidos.count, "pedido aguardando triagem", "pedidos aguardando triagem") %>
      </p>
    </div>
    <p class="rently-copy max-w-xl">
      Selecione um pedido, registre o parecer e execute o contrato quando a análise financeira for positiva.
    </p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <section class="rently-panel">
      <div class="flex items-center justify-between gap-4 px-5 py-4 border-b-2 border-gray-900">
        <h2 class="rently-display text-2xl font-black">Aguardando análise</h2>
        <span class="rently-status-badge" style="background:#fff7d6;color:#8a5b00;"><%= @pending_pedidos.count %> pendente(s)</span>
      </div>

      <% if @pending_pedidos.any? %>
        <ul class="divide-y divide-gray-200">
          <% @pending_pedidos.each do |pedido| %>
            <li class="flex flex-col gap-4 px-5 py-4 sm:flex-row sm:items-center sm:justify-between">
              <div>
                <p class="text-sm font-black text-gray-900"><%= pedido.client.name %></p>
                <p class="text-xs font-bold text-gray-500">
                  <%= pedido.automovel.brand %> <%= pedido.automovel.model %> · Solicitado em <%= pedido.request_date.strftime("%d/%m/%Y") %>
                </p>
              </div>
              <%= link_to "Abrir análise", pedido_path(pedido), class: "rently-button sm:w-auto w-full" %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="px-5 py-16 text-center">
          <p class="rently-display text-3xl font-black">Fila vazia.</p>
          <p class="text-sm font-bold text-gray-500 mt-2">Nenhum pedido novo aguardando triagem.</p>
        </div>
      <% end %>
    </section>

    <section class="rently-panel">
      <div class="flex items-center justify-between gap-4 px-5 py-4 border-b-2 border-gray-900">
        <h2 class="rently-display text-2xl font-black">Em análise por você</h2>
        <span class="rently-status-badge" style="background:#e3f4ff;color:#125d83;"><%= @reviewing_pedidos.count %> em análise</span>
      </div>

      <% if @reviewing_pedidos.any? %>
        <ul class="divide-y divide-gray-200">
          <% @reviewing_pedidos.each do |pedido| %>
            <li class="flex flex-col gap-4 px-5 py-4 sm:flex-row sm:items-center sm:justify-between">
              <div>
                <p class="text-sm font-black text-gray-900"><%= pedido.client.name %></p>
                <p class="text-xs font-bold text-gray-500">
                  <%= pedido.automovel.brand %> <%= pedido.automovel.model %> · Atualizado em <%= pedido.updated_at.strftime("%d/%m/%Y") %>
                </p>
              </div>
              <%= link_to "Continuar", pedido_path(pedido), class: "rently-button-ghost sm:w-auto w-full" %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="px-5 py-16 text-center">
          <p class="rently-display text-3xl font-black">Nada na sua mesa.</p>
          <p class="text-sm font-bold text-gray-500 mt-2">Abra um pedido pendente para começar.</p>
        </div>
      <% end %>
    </section>
  </div>

  <section class="rently-panel">
    <div class="flex items-center justify-between gap-4 px-5 py-4 border-b-2 border-gray-900">
      <h2 class="rently-display text-2xl font-black">Últimos pareceres</h2>
      <span class="rently-status-badge" style="background:#eef4ec;color:#4e5d53;"><%= @finished_pedidos.count %> registro(s)</span>
    </div>

    <% if @finished_pedidos.any? %>
      <ul class="divide-y divide-gray-200">
        <% @finished_pedidos.each do |pedido| %>
          <li class="grid grid-cols-1 gap-3 px-5 py-4 sm:grid-cols-3 sm:items-center">
            <div>
              <p class="text-sm font-black text-gray-900"><%= pedido.client.name %></p>
              <p class="text-xs font-bold text-gray-500"><%= pedido.automovel.brand %> <%= pedido.automovel.model %> · <%= pedido.request_date.strftime("%d/%m/%Y") %></p>
            </div>
            <%= render "dashboard/status_badge", status: pedido.status %>
            <%= link_to "Ver pedido", pedido_path(pedido), class: "rently-button-ghost sm:justify-self-end" %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="px-5 py-16 text-center">
        <p class="rently-display text-3xl font-black">Sem pareceres ainda.</p>
      </div>
    <% end %>
  </section>
</div>
