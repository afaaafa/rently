<% content_for :title, "Atualizar senha — Rently" %>

<div class="rently-auth">
  <div class="rently-panel rently-panel-pad">
  <% if alert = flash[:alert] %>
    <p class="py-2 px-3 bg-red-50 mb-5 text-red-500 font-bold rounded-lg inline-block" id="alert"><%= alert %></p>
  <% end %>

    <span class="rently-eyebrow">Nova credencial</span>
    <h1 class="rently-section-title mt-3">Atualizar senha</h1>
    <p class="rently-copy mt-4">Defina uma nova senha para voltar ao fluxo de pedidos e análise.</p>

    <%= form_with url: password_path(params[:token]), method: :put, class: "block mt-6 space-y-5" do |form| %>
    <div>
      <%= form.label :password, "Nova senha", class: "rently-label" %>
      <%= form.password_field :password, required: true, autocomplete: "new-password", placeholder: "Nova senha", maxlength: 72, class: "rently-input" %>
    </div>

    <div>
      <%= form.label :password_confirmation, "Confirmar senha", class: "rently-label" %>
      <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", placeholder: "Repita a nova senha", maxlength: 72, class: "rently-input" %>
    </div>

    <div>
      <%= form.submit "Salvar senha", class: "rently-button w-full sm:w-auto cursor-pointer" %>
    </div>
  <% end %>
  </div>
</div>
