<div
  data-controller="vehicle-card"
  data-url="<%= automovel_path(automovel) %>"
  data-action="click->vehicle-card#navigate"
  class="rently-vehicle-card group"
>
  <%# Image %>
  <div class="rently-vehicle-media">
    <% if automovel.image.attached? %>
      <%= image_tag automovel.image %>
    <% else %>
      <div class="h-full flex items-center justify-center">
        <%= icon "car-profile", variant: "regular", class: "size-20 text-gray-500" %>
      </div>
    <% end %>
  </div>

  <%# Card body %>
  <div class="p-4">
    <div class="flex items-start justify-between">
      <div>
        <p class="text-xs font-black uppercase text-gray-500"><%= automovel.brand %></p>
        <h3 class="rently-display text-2xl font-black mt-0.5"><%= automovel.model %></h3>
      </div>
      <span class="rently-status-pill">Disponível</span>
    </div>

    <div class="rently-meta mt-4">
      <span>
        <%= icon "calendar", variant: "regular", class: "size-4" %>
        <%= automovel.year %>
      </span>
      <span>
        <%= icon "identification-card", variant: "regular", class: "size-4" %>
        <%= automovel.plate %>
      </span>
      <span>
        <%= number_to_currency(automovel.daily_rate, unit: "R$ ", separator: ",", delimiter: ".") %>/dia
      </span>
    </div>

    <div class="mt-4 pt-4 border-t border-gray-200">
      <span class="inline-flex w-full items-center justify-between text-sm font-black">
        Ver disponibilidade
        <%= icon "arrow-up-right", variant: "regular", class: "size-4" %>
      </span>
    </div>
  </div>
</div>
