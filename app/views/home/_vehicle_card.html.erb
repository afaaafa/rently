<div
  data-controller="vehicle-card"
  data-url="<%= automovel_path(automovel) %>"
  data-action="click->vehicle-card#navigate"
  class="group relative bg-white rounded-2xl border border-gray-200 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-200 overflow-hidden"
>
  <%# Image %>
  <% if automovel.image.attached? %>
    <%= image_tag automovel.image, class: "h-44 w-full object-cover" %>
  <% else %>
    <div class="h-44 bg-linear-to-br from-slate-100 to-slate-200 flex items-center justify-center">
      <%= icon "car", variant: "regular", class: "size-20 text-slate-300" %>
    </div>
  <% end %>

  <%# Card body %>
  <div class="p-4">
    <div class="flex items-start justify-between">
      <div>
        <p class="text-xs font-semibold uppercase tracking-wide text-blue-600"><%= automovel.brand %></p>
        <h3 class="text-lg font-bold text-gray-900 mt-0.5"><%= automovel.model %></h3>
      </div>
      <span class="text-xs bg-green-100 text-green-700 font-semibold px-2 py-1 rounded-full">Disponível</span>
    </div>

    <div class="mt-3 flex items-center gap-4 text-sm text-gray-500">
      <span class="flex items-center gap-1">
        <%= icon "calendar", variant: "regular", class: "size-4" %>
        <%= automovel.year %>
      </span>
      <span class="flex items-center gap-1">
        <%= icon "identification-card", variant: "regular", class: "size-4" %>
        <%= automovel.plate %>
      </span>
    </div>

    <div class="mt-4 pt-4 border-t border-gray-100">
      <span class="inline-block w-full text-center text-sm font-semibold text-blue-600 group-hover:text-blue-500">
        Ver detalhes →
      </span>
    </div>
  </div>
</div>
