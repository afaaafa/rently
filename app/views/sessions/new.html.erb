<% content_for :title, "Entrar — Rently" %>

<div class="rently-auth">
  <div class="rently-panel rently-panel-pad justify-center items-center">
  <% if alert = flash[:alert] %>
    <p class="py-2 px-3 bg-red-50 mb-5 text-red-500 font-bold rounded-lg inline-block" id="alert"><%= alert %></p>
  <% end %>

  <% if notice = flash[:notice] %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-bold rounded-lg inline-block" id="notice"><%= notice %></p>
  <% end %>

    <span class="rently-eyebrow">Acesso ao sistema</span>
    <h1 class="rently-section-title mt-3">Entrar na Rently</h1>
    <p class="rently-copy mt-4">Use suas credenciais para acompanhar pedidos, avaliar solicitações ou gerenciar a frota.</p>

    <%= form_with url: session_url, class: "block mt-6 space-y-5" do |form| %>
    <div>
      <%= form.label :email_address, "E-mail", class: "rently-label" %>
      <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", placeholder: "voce@exemplo.com", value: params[:email_address], class: "rently-input" %>
    </div>

    <div>
      <%= form.label :password, "Senha", class: "rently-label" %>
      <%= form.password_field :password, required: true, autocomplete: "current-password", placeholder: "Sua senha", maxlength: 72, class: "rently-input" %>
    </div>

    <div class="sm:flex sm:items-center sm:gap-4">
      <div>
        <%= form.submit "Entrar", class: "rently-button w-full sm:w-auto cursor-pointer" %>
      </div>

      <div class="mt-4 text-sm font-bold text-gray-500 sm:mt-0">
        <%= link_to "Esqueci minha senha", new_password_path, class: "text-gray-700 underline hover:no-underline" %>
      </div>
    </div>

    <p class="text-sm font-bold text-gray-500">
      Ainda não tem conta?
      <%= link_to "Criar conta", new_registration_path, class: "text-gray-900 underline hover:no-underline" %>
    </p>
  <% end %>
  </div>
</div>
