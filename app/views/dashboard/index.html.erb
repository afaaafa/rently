<% content_for :title, "Dashboard — Rently" %>

<div class="space-y-8">

  <%# Header %>
  <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <span class="rently-eyebrow">Mesa de análise</span>
      <h1 class="rently-section-title mt-3">
        Olá, <%= Current.user.name&.split&.first || Current.user.email_address %>
      </h1>
      <p class="text-sm font-bold text-gray-600 mt-2"><%= Current.user.class.name %> · <%= Date.today.strftime("%d/%m/%Y") %></p>
    </div>
    <p class="rently-copy max-w-xl">
      Pedidos entram pela frota, passam pela análise financeira e avançam para contrato quando o parecer é positivo.
    </p>
  </div>

  <div class="rently-ops-strip">
    <div>
      <p class="text-xs font-black uppercase text-gray-500">Fila</p>
      <p class="rently-display mt-3 text-3xl font-black leading-none">Pedidos aguardando triagem.</p>
    </div>
    <div>
      <p class="text-xs font-black uppercase text-gray-500">Parecer</p>
      <p class="rently-display mt-3 text-3xl font-black leading-none">Aprovação ou recusa registrada.</p>
    </div>
    <div>
      <p class="text-xs font-black uppercase text-gray-500">Contrato</p>
      <p class="rently-display mt-3 text-3xl font-black leading-none">Propriedade cliente, empresa ou banco.</p>
    </div>
  </div>

  <%# Stats %>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
    <%= render "stat_card",
          label: "Aguardando análise",
          value: @pending_count,
          color: "yellow",
          icon: "clock" %>

    <%= render "stat_card",
          label: "Em análise (seus)",
          value: @reviewing_count,
          color: "blue",
          icon: "search" %>

    <%= render "stat_card",
          label: "Veículos na frota",
          value: @vehicles_count,
          color: "slate",
          icon: "car" %>

    <%= render "stat_card",
          label: "Disponíveis",
          value: @available_count,
          color: "green",
          icon: "check" %>
  </div>

  <%# Pedidos table + Quick actions %>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

    <%# Pending pedidos %>
    <div class="lg:col-span-2 rently-panel">
      <div class="flex items-center justify-between gap-4 px-5 py-4 border-b-2 border-gray-900">
        <h2 class="rently-display text-2xl font-black">Pedidos pendentes</h2>
        <span class="rently-status-badge" style="background:#f8faf7;color:#12140f;"><%= @recent_pedidos.count %> pedido(s)</span>
      </div>

      <% if @recent_pedidos.any? %>
        <ul class="divide-y divide-gray-200">
          <% @recent_pedidos.each do |pedido| %>
            <li class="flex items-center justify-between gap-4 px-5 py-4 hover:bg-green-50 transition-colors">
              <div>
                <p class="text-sm font-black text-gray-900"><%= pedido.client.name %></p>
                <p class="text-xs font-bold text-gray-500">
                  <%= pedido.automovel.brand %> <%= pedido.automovel.model %> · Solicitado em <%= pedido.request_date.strftime("%d/%m/%Y") %>
                </p>
              </div>
              <div class="flex items-center gap-2">
                <%= render "status_badge", status: pedido.status %>
                <% if fleet_manager? %>
                  <%= link_to "Analisar", pedido_path(pedido), class: "rently-button-ghost" %>
                <% end %>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="px-5 py-16 text-center">
          <p class="rently-display text-3xl font-black">Nenhum pedido pendente.</p>
          <p class="text-sm font-bold text-gray-500 mt-2">A fila de análise está limpa.</p>
        </div>
      <% end %>
    </div>

    <%# Quick actions %>
    <div class="space-y-3">
      <h2 class="rently-display text-2xl font-black">Ações rápidas</h2>

      <% if fleet_manager? %>
        <%= link_to pedidos_path, class: "rently-action-row group" do %>
          <div class="rently-stat-icon" style="background:#fff7d6;color:#8a5b00;">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5h6M9 9h6m-7 4h8m-9 4h7M6 3h12v18H6z"/>
            </svg>
          </div>
          <div>
            <p class="text-sm font-black text-gray-900">Analisar pedidos</p>
            <p class="text-xs font-bold text-gray-500">Selecionar, aprovar ou recusar</p>
          </div>
        <% end %>
      <% end %>

      <%= link_to automoveis_path, class: "rently-action-row group" do %>
        <div class="rently-stat-icon" style="background:#e3f4ff;color:#125d83;">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M9 17a2 2 0 11-4 0 2 2 0 014 0zm10 0a2 2 0 11-4 0 2 2 0 014 0zM13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10l2 1h2"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-black text-gray-900"><%= fleet_manager? ? "Gerenciar frota" : "Consultar frota" %></p>
          <p class="text-xs font-bold text-gray-500"><%= @vehicles_count %> veículos cadastrados</p>
        </div>
      <% end %>

      <% if Current.user.is_a?(Banco) %>
        <%= link_to creditos_path, class: "rently-action-row group" do %>
          <div class="rently-stat-icon" style="background:#fff7d6;color:#8a5b00;">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-2.21 0-4 1.12-4 2.5S9.79 13 12 13s4 1.12 4 2.5S14.21 18 12 18m0-10V6m0 12v-2"/>
            </svg>
          </div>
          <div>
            <p class="text-sm font-black text-gray-900">Analisar crédito</p>
            <p class="text-xs font-bold text-gray-500">Contratos aprovados para financiamento</p>
          </div>
        <% end %>
      <% end %>

      <% if fleet_manager? %>
        <%= link_to new_automovel_path, class: "rently-action-row group" do %>
          <div class="rently-stat-icon" style="background:#b6ff2e;color:#365900;">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
          </div>
          <div>
            <p class="text-sm font-black text-gray-900">Novo veículo</p>
            <p class="text-xs font-bold text-gray-500">Cadastrar na frota</p>
          </div>
        <% end %>
      <% end %>
    </div>

  </div>
</div>
