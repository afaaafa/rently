<% styles = {
  "pending"      => "background:#fff7d6;color:#8a5b00;",
  "under_review" => "background:#e3f4ff;color:#125d83;",
  "approved"     => "background:#b6ff2e;color:#365900;",
  "rejected"     => "background:#fff2f0;color:#b62518;",
  "cancelled"    => "background:#eef4ec;color:#4e5d53;"
} %>
<% labels = {
  "pending"      => "Pendente",
  "under_review" => "Em análise",
  "approved"     => "Aprovado",
  "rejected"     => "Recusado",
  "cancelled"    => "Cancelado"
} %>

<span class="rently-status-badge" style="<%= styles[status] %>">
  <%= labels[status] %>
</span>
