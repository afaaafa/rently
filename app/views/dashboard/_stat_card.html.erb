<% colors = {
  "yellow" => { bg: "background:#fff7d6;", text: "color:#8a5b00;" },
  "blue"   => { bg: "background:#e3f4ff;", text: "color:#125d83;" },
  "green"  => { bg: "background:#b6ff2e;", text: "color:#365900;" },
  "slate"  => { bg: "background:#eef4ec;", text: "color:#4e5d53;" }
} %>
<% c = colors[color] %>

<div class="rently-stat-card">
  <div class="rently-stat-icon" style="<%= c[:bg] %>">
    <% if icon == "clock" %>
      <svg class="w-6 h-6" style="<%= c[:text] %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
    <% elsif icon == "search" %>
      <svg class="w-6 h-6" style="<%= c[:text] %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
    <% elsif icon == "car" %>
      <svg class="w-6 h-6" style="<%= c[:text] %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M9 17a2 2 0 11-4 0 2 2 0 014 0zm10 0a2 2 0 11-4 0 2 2 0 014 0zM13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10l2 1h2"/>
      </svg>
    <% elsif icon == "check" %>
      <svg class="w-6 h-6" style="<%= c[:text] %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
      </svg>
    <% end %>
  </div>
  <div>
    <p class="rently-display text-5xl font-black leading-none"><%= value %></p>
    <p class="text-xs font-black uppercase text-gray-500 mt-1"><%= label %></p>
  </div>
</div>
