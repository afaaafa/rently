<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Rently" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Rently">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="antialiased">
    <%# Navbar %>
    <header class="rently-app-header">
      <div class="rently-container h-16 flex items-center justify-between gap-4">
        <%= link_to root_path, class: "rently-brand" do %>
          <span class="rently-brand-mark">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M18.92 6.01C18.72 5.42 18.16 5 17.5 5h-11c-.66 0-1.21.42-1.42 1.01L3 12v8c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-1h12v1c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-8l-2.08-5.99zM6.85 7h10.29l1.08 3.11H5.77L6.85 7zM19 17H5v-5h14v5z"/>
              <circle cx="7.5" cy="14.5" r="1.5"/>
              <circle cx="16.5" cy="14.5" r="1.5"/>
            </svg>
          </span>
          <span class="rently-display text-2xl font-black">Rently</span>
        <% end %>

        <nav class="rently-nav">
          <%= link_to "Slides", slides_path, class: "rently-nav-link" %>
          <% if authenticated? %>
            <% if Current.user.is_a?(Agente) %>
              <%= link_to "Painel", dashboard_path, class: "rently-nav-link" %>
              <% if Current.user.is_a?(Empresa) %>
                <%= link_to "Pedidos", pedidos_path, class: "rently-nav-link" %>
              <% end %>
              <% if Current.user.is_a?(Banco) %>
                <%= link_to "Crédito", creditos_path, class: "rently-nav-link" %>
              <% end %>
              <%= link_to "Frota", automoveis_path, class: "rently-nav-link" %>
            <% end %>
            <% if Current.user.is_a?(Cliente) %>
              <%= link_to "Meus pedidos", pedidos_path, class: "rently-nav-link" %>
            <% end %>
            <span class="rently-nav-user">
              <%= Current.user.name || Current.user.email_address %>
            </span>
            <%= button_to "Sair", session_path, method: :delete,
                  class: "rently-nav-link cursor-pointer" %>
          <% else %>
            <%= link_to "Entrar", new_session_path, class: "rently-nav-link" %>
            <%= link_to "Criar conta", new_registration_path, class: "rently-button" %>
          <% end %>
        </nav>
      </div>
    </header>

    <%# Flash %>
    <div class="fixed top-16 inset-x-0 z-10 pointer-events-none">
      <div class="rently-container pt-3 flex flex-col gap-2">
        <% if notice = flash[:notice] %>
          <p class="pointer-events-auto py-2 px-4 bg-green-50 border border-green-200 text-green-700 text-sm font-bold rounded-lg shadow-sm"
             data-controller="flash" data-action="click->flash#dismiss">
            <%= notice %>
          </p>
        <% end %>
        <% if alert = flash[:alert] %>
          <p class="pointer-events-auto py-2 px-4 bg-red-50 border border-red-200 text-red-700 text-sm font-bold rounded-lg shadow-sm"
             data-controller="flash" data-action="click->flash#dismiss">
            <%= alert %>
          </p>
        <% end %>
      </div>
    </div>

    <main class="rently-main">
      <div class="rently-container">
        <%= yield %>
      </div>
    </main>
  </body>
</html>
