<%= form_with model: automovel, class: "space-y-6" do |f| %>
  <% if automovel.errors.any? %>
    <div class="bg-red-50 border-2 border-red-200 rounded-lg p-4">
      <p class="text-sm font-black text-red-700 mb-1">
        <%= pluralize(automovel.errors.count, "erro") %> impediram o salvamento:
      </p>
      <ul class="list-disc list-inside text-sm font-bold text-red-600 space-y-0.5">
        <% automovel.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <div>
      <%= f.label :brand, "Marca", class: "rently-label" %>
      <%= f.text_field :brand, placeholder: "ex: Toyota",
            class: "rently-input" %>
    </div>

    <div>
      <%= f.label :model, "Modelo", class: "rently-label" %>
      <%= f.text_field :model, placeholder: "ex: Hilux",
            class: "rently-input" %>
    </div>

    <div>
      <%= f.label :year, "Ano", class: "rently-label" %>
      <%= f.number_field :year, placeholder: "ex: 2023", min: 1980, max: Date.today.year + 1,
            class: "rently-input" %>
    </div>

    <div>
      <%= f.label :plate, "Placa", class: "rently-label" %>
      <%= f.text_field :plate, placeholder: "ex: ABC-1234",
            class: "rently-input" %>
    </div>

    <div>
      <%= f.label :matricula, "Matrícula", class: "rently-label" %>
      <%= f.text_field :matricula, placeholder: "ex: MAT-001",
            class: "rently-input" %>
    </div>

    <div>
      <%= f.label :daily_rate, "Diária", class: "rently-label" %>
      <%= f.number_field :daily_rate, placeholder: "ex: 180.00", step: "0.01", min: "0",
            class: "rently-input" %>
    </div>
  </div>

  <%# Image upload %>
  <div data-controller="image-preview">
    <%= f.label :image, "Foto do veículo", class: "rently-label" %>

    <% if automovel.image.attached? %>
      <div class="mb-3">
        <%= image_tag automovel.image, class: "h-40 w-full object-cover rounded-lg border-2 border-gray-900" %>
      </div>
    <% end %>

    <label class="rently-dropzone"
           data-image-preview-target="dropzone">
      <div class="flex flex-col items-center gap-1 text-gray-500" data-image-preview-target="placeholder">
        <%= icon "image", variant: "regular", class: "size-8" %>
        <p class="text-sm font-black">Clique para selecionar uma imagem</p>
        <p class="text-xs font-bold">PNG, JPG, WEBP até 5MB</p>
      </div>
      <img data-image-preview-target="preview" class="hidden h-full w-full object-cover rounded-lg" />
      <%= f.file_field :image, accept: "image/*", class: "hidden",
            data: { action: "change->image-preview#show", image_preview_target: "input" } %>
    </label>
  </div>

  <div class="flex flex-wrap items-center gap-4 pt-2">
    <%= f.submit automovel.new_record? ? "Cadastrar veículo" : "Salvar alterações",
          class: "rently-button cursor-pointer" %>
    <%= link_to "Cancelar", automoveis_path,
          class: "rently-button-ghost" %>
  </div>
<% end %>
