<% content_for :title, "Frota — Rently" %>

<div>
  <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between mb-6">
    <div>
      <span class="rently-eyebrow">Inventário operacional</span>
      <h1 class="rently-section-title mt-3">Frota de veículos</h1>
      <p class="text-sm font-bold text-gray-600 mt-2"><%= pluralize(@automoveis.count, "veículo cadastrado", "veículos cadastrados") %></p>
    </div>
    <% if fleet_manager? %>
      <%= link_to "Novo veículo", new_automovel_path, class: "rently-button" %>
    <% end %>
  </div>

  <% if @automoveis.any? %>
    <div class="rently-grid">
      <% @automoveis.each do |automovel| %>
        <div class="rently-vehicle-card flex flex-col">
          <%# Image %>
          <div class="rently-vehicle-media">
            <% if automovel.image.attached? %>
              <%= image_tag automovel.image %>
            <% else %>
              <div class="h-full flex items-center justify-center">
                <%= icon "car-profile", variant: "regular", class: "size-16 text-gray-500" %>
              </div>
            <% end %>
          </div>

          <div class="p-4 flex flex-col flex-1">
            <div class="flex-1">
              <p class="text-xs font-black uppercase text-gray-500"><%= automovel.brand %></p>
              <h3 class="rently-display text-2xl font-black mt-0.5"><%= automovel.model %> <span class="text-gray-500 font-bold text-base"><%= automovel.year %></span></h3>
              <div class="rently-meta mt-3">
                <span>Placa <strong class="text-gray-900"><%= automovel.plate %></strong></span>
                <span>Mat. <strong class="text-gray-900"><%= automovel.matricula %></strong></span>
                <span>Diária <strong class="text-gray-900"><%= number_to_currency(automovel.daily_rate, unit: "R$ ", separator: ",", delimiter: ".") %></strong></span>
              </div>
            </div>

            <div class="mt-4 flex items-center gap-2 pt-3 border-t border-gray-200">
              <%= link_to automovel_path(automovel),
                    title: "Ver",
                    class: "rently-button-ghost" do %>
                <%= icon "eye", variant: "regular", class: "size-5" %>
              <% end %>
              <% if fleet_manager? %>
                <%= link_to edit_automovel_path(automovel),
                      title: "Editar",
                      class: "rently-button-ghost" do %>
                  <%= icon "pencil-simple", variant: "regular", class: "size-5" %>
                <% end %>
                <%= button_to automovel_path(automovel), method: :delete,
                      title: "Remover",
                      form: { data: { turbo_confirm: "Tem certeza que deseja remover #{automovel.brand} #{automovel.model}?" } },
                      class: "rently-button-danger cursor-pointer" do %>
                  <%= icon "trash", variant: "regular", class: "size-5" %>
                <% end %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="rently-empty">
      <p class="rently-display text-3xl font-black">Nenhum veículo cadastrado.</p>
      <% if fleet_manager? %>
        <%= link_to "Cadastrar o primeiro", new_automovel_path, class: "rently-button mt-4" %>
      <% end %>
    </div>
  <% end %>
</div>
