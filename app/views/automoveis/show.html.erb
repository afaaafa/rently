<% content_for :title, "#{@automovel.brand} #{@automovel.model} — Rently" %>

<div class="w-full max-w-3xl mx-auto">
  <%# Back %>
  <%= link_to "← Voltar para veículos", root_path, class: "text-sm text-gray-500 hover:text-gray-700" %>

  <div class="mt-6 bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
    <%# Image placeholder %>
    <div class="h-64 bg-gradient-to-br from-slate-100 to-slate-200 flex items-center justify-center">
      <svg class="w-32 h-32 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
          d="M9 17a2 2 0 11-4 0 2 2 0 014 0zm10 0a2 2 0 11-4 0 2 2 0 014 0z"/>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
          d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10l2 1h2m0-11h6l3 4h2a1 1 0 011 1v4l-2 1h-1"/>
      </svg>
    </div>

    <div class="p-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-semibold uppercase tracking-wide text-blue-600"><%= @automovel.brand %></p>
          <h1 class="text-3xl font-extrabold text-gray-900 mt-1"><%= @automovel.model %></h1>
        </div>
        <span class="bg-green-100 text-green-700 font-semibold text-sm px-3 py-1.5 rounded-full">Disponível</span>
      </div>

      <dl class="mt-6 grid grid-cols-2 gap-4 sm:grid-cols-3">
        <div class="bg-gray-50 rounded-xl p-4">
          <dt class="text-xs text-gray-500 uppercase tracking-wide">Ano</dt>
          <dd class="mt-1 text-lg font-bold text-gray-800"><%= @automovel.year %></dd>
        </div>
        <div class="bg-gray-50 rounded-xl p-4">
          <dt class="text-xs text-gray-500 uppercase tracking-wide">Placa</dt>
          <dd class="mt-1 text-lg font-bold text-gray-800"><%= @automovel.plate %></dd>
        </div>
        <div class="bg-gray-50 rounded-xl p-4">
          <dt class="text-xs text-gray-500 uppercase tracking-wide">Matrícula</dt>
          <dd class="mt-1 text-lg font-bold text-gray-800"><%= @automovel.matricula %></dd>
        </div>
      </dl>

      <div class="mt-8">
        <%= link_to "Solicitar aluguel",
              "#",
              class: "block w-full text-center bg-blue-600 hover:bg-blue-500 text-white font-bold py-3 px-6 rounded-xl transition-colors" %>
      </div>
    </div>
  </div>
</div>
