<% content_for :title, "#{@automovel.brand} #{@automovel.model} — Rently" %>

<div class="max-w-6xl mx-auto">
  <%= link_to "Voltar para veículos", root_path, class: "rently-button-ghost" %>

  <div class="mt-6 grid grid-cols-1 lg:grid-cols-5 gap-6 items-start">
    <%# Image %>
    <div class="lg:col-span-3 rently-panel">
      <div class="rently-vehicle-media" style="height: min(62vh, 34rem);">
        <% if @automovel.image.attached? %>
          <%= image_tag @automovel.image %>
        <% else %>
          <div class="h-full flex items-center justify-center">
            <%= icon "car-profile", variant: "regular", class: "size-32 text-gray-500" %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="lg:col-span-2 rently-panel rently-panel-pad">
      <div class="flex items-start justify-between gap-4">
        <div>
          <span class="rently-status-pill">Disponível</span>
          <p class="text-sm font-black uppercase text-gray-500 mt-5"><%= @automovel.brand %></p>
          <h1 class="rently-display text-5xl font-black leading-none mt-1"><%= @automovel.model %></h1>
        </div>
        <div class="flex items-center gap-2 shrink-0">
          <% if authenticated? && fleet_manager? %>
            <%= link_to edit_automovel_path(@automovel),
                  title: "Editar",
                  class: "rently-button-ghost" do %>
              <%= icon "pencil-simple", variant: "regular", class: "size-5" %>
            <% end %>
            <%= button_to automovel_path(@automovel), method: :delete,
                  title: "Remover",
                  form: { data: { turbo_confirm: "Tem certeza?" } },
                  class: "rently-button-danger cursor-pointer" do %>
              <%= icon "trash", variant: "regular", class: "size-5" %>
            <% end %>
          <% end %>
        </div>
      </div>

      <dl class="mt-6 grid grid-cols-1 sm:grid-cols-3 lg:grid-cols-1 gap-3">
        <div class="rently-spec p-4">
          <dt class="text-xs font-black text-gray-500 uppercase">Ano</dt>
          <dd class="rently-display mt-1 text-3xl font-black"><%= @automovel.year %></dd>
        </div>
        <div class="rently-spec p-4">
          <dt class="text-xs font-black text-gray-500 uppercase">Placa</dt>
          <dd class="rently-display mt-1 text-3xl font-black"><%= @automovel.plate %></dd>
        </div>
        <div class="rently-spec p-4">
          <dt class="text-xs font-black text-gray-500 uppercase">Matrícula</dt>
          <dd class="rently-display mt-1 text-3xl font-black"><%= @automovel.matricula %></dd>
        </div>
        <div class="rently-spec p-4">
          <dt class="text-xs font-black text-gray-500 uppercase">Diária</dt>
          <dd class="rently-display mt-1 text-3xl font-black"><%= number_to_currency(@automovel.daily_rate, unit: "R$ ", separator: ",", delimiter: ".") %></dd>
        </div>
      </dl>

      <% if authenticated? && Current.user.is_a?(Cliente) %>
        <div class="mt-8">
          <%= link_to "Solicitar aluguel", new_pedido_path(automovel_id: @automovel.id),
                class: "rently-button w-full" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
